   "source": [
    "df = pd.concat([pd.concat(data[op][\"0\"]) for op in data.keys()]).reset_index(drop=True)\n",
    "df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_train, df_test = train_test_split(df, test_size=0.4, random_state=42)\n",
    "df_train[\"state_encoded\"] = df_train[\"state\"].map({\"good\": 0, \"bad\": 1})\n",
    "df_test[\"state_encoded\"] = df_test[\"state\"].map({\"good\": 0, \"bad\": 1})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Using full, imbalanced training set.\n"
     ]
    }
   ],
   "source": [
    "if config[\"downsample_majority_class\"]:\n",
    "    print(\"Applying majority class downsampling to the training set...\")\n",
    "    # Separate classes based on encoded state\n",
    "    df_good = df_train[df_train[\"state_encoded\"] == 0]\n",
    "    df_bad = df_train[df_train[\"state_encoded\"] == 1]\n",
    "\n",
    "    # Identify minority and majority sizes\n",
    "    minority_size = min(len(df_good), len(df_bad))\n",
    "\n",
    "    # Downsample both to match the minority size\n",
    "    df_good_downsampled = df_good.sample(n=minority_size, random_state=42)\n",
    "    df_bad_downsampled = df_bad.sample(n=minority_size, random_state=42)\n",
    "\n",
    "    # Recombine\n",
    "    df_train = pd.concat([df_good_downsampled, df_bad_downsampled]).sample(\n",
    "        frac=1, random_state=42\n",
    "    )\n",
    "    print(f\"New training set size: {len(df_train)} (Balanced)\")\n",
    "else:\n",
    "    print(\"Using full, imbalanced training set.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
